# ── oh-my-lazybones self-hosted configuration ──
# Copy this file to .env and fill in your values.

# --- Database ---
# SQLite (zero-dependency, default):
#   DATABASE_URL=sqlite+aiosqlite:///lazybones.db
# MySQL (production):
#   DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/lazybones
DATABASE_URL=sqlite+aiosqlite:///lazybones.db

# --- Search ---
# Meilisearch (production):
#   MEILI_URL=http://localhost:7700
#   MEILI_MASTER_KEY=your-master-key-here
# SQLite LIKE fallback (leave MEILI_URL empty):
#   MEILI_URL=
MEILI_URL=

# --- Meilisearch master key ---
# Required only when MEILI_URL is set.
# MEILI_MASTER_KEY=your-master-key-here

# --- Environment ---
# development | production | selfhosted
ENVIRONMENT=selfhosted
